{
    "name": "@wkulinski/lsm",
    "type": "module",
    "version": "0.1.0",
    "description": "Declarative manager for synchronizing and publishing LLM skills across AI agents.",
    "author": "Wojciech Kuliński",
    "license": "MIT",
    "engines": {
        "node": ">=20"
    },
    "homepage": "https://github.com/wkulinski/lsm",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wkulinski/lsm.git"
    },
    "bugs": {
        "url": "https://github.com/wkulinski/lsm/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": "./dist/index.mjs",
        "./bin": "./dist/bin.mjs",
        "./package.json": "./package.json"
    },
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test:typecheck": "tsc --noEmit --project tsconfig.vitest.json",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build",
        "lint:js": "eslint",
        "lint:js:fix": "eslint --fix",
        "lint:js:fix:dry": "eslint --fix-dry-run",
        "lint:ts:typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.0.3",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.57.0",
        "@vitest/coverage-v8": "^4.0.18",
        "bumpp": "^10.3.2",
        "eslint": "^10.0.3",
        "globals": "^17.6.0",
        "tsdown": "^0.18.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.16"
    },
    "directories": {
        "test": "tests"
    },
    "keywords": [],
    "dependencies": {
        "commander": "^14.0.3",
        "yaml": "^2.9.0"
    },
    "bin": {
        "lsm": "bin/lsm"
    }
}
