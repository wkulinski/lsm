{
    "outputDefaults": {
        "outputMode": "quiet-on-pass",
        "failTailLines": 120,
        "maxOutputBytes": 20000,
        "stripAnsi": true,
        "parserInputBytes": 5242880,
        "parser": "generic-tail"
    },
    "patternSets": {
        "project-js-ts-checks": [
            "@js-ts-safe"
        ]
    },
    "sectionOrder": [
        "ALWAYS_FULL",
        "ALWAYS_ON_RERUN",
        "SHELL_SCRIPTS_CHANGED",
        "JS_TS_CHANGED",
        "MARKDOWN_CHANGED",
        "QA_CONFIG_CHANGED"
    ],
    "sections": {
        "ALWAYS_FULL": {
            "patterns": [],
            "commands": [],
            "runOn": [
                "full"
            ],
            "requiresFinalFullPass": false
        },
        "ALWAYS_ON_RERUN": {
            "patterns": [],
            "commands": [],
            "runOn": [
                "rerun"
            ],
            "requiresFinalFullPass": false
        },
        "SHELL_SCRIPTS_CHANGED": {
            "patterns": [
                ".agents/skills/**/scripts/*.sh"
            ],
            "commands": [
                "find .agents/skills -type f -path '*/scripts/*.sh' -print0 | xargs -0 -r -n1 bash -n"
            ],
            "runOn": [
                "full",
                "rerun"
            ],
            "requiresFinalFullPass": false
        },
        "JS_TS_CHANGED": {
            "patterns": [
                "@project-js-ts-checks"
            ],
            "cache": {
                "enabled": true
            },
            "commands": [
                {
                    "cmd": "npm --silent run lint:js -- --format json",
                    "parser": "eslint-json"
                },
                "npm test"
            ],
            "runOn": [
                "full",
                "rerun"
            ],
            "requiresFinalFullPass": false
        },
        "MARKDOWN_CHANGED": {
            "patterns": [
                "**/*.md"
            ],
            "commands": [
                "git diff --check"
            ],
            "runOn": [
                "full",
                "rerun"
            ],
            "requiresFinalFullPass": false
        },
        "QA_CONFIG_CHANGED": {
            "patterns": [
                ".agents/qa-run.matrix.json",
                ".agents/skills/qa-run/**"
            ],
            "commands": [
                "node .agents/skills/qa-run/scripts/run-matrix.mjs --help"
            ],
            "runOn": [
                "full",
                "rerun"
            ],
            "requiresFinalFullPass": false
        }
    }
}
